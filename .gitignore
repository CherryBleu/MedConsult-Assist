# ===== 基础设施（infra/）=====
# .env 含本地密码，不入仓（infra/.env.example 是模板）
infra/.env
# Docker 持久化产物（compose 用 named volume，下面这些只防误投）
infra/mysql/log/
infra/qdrant/storage/
infra/rabbitmq/

# ===== 工具产物（不入仓库）=====
.playwright-mcp/
.zcode/

# ===== 前端（frontend/）=====
frontend/node_modules/
frontend/dist/
frontend/.env.local
frontend/npm-debug.log*
frontend/.vite-cache/
# Playwright e2e 产物（测试代码 e2e/*.spec.ts 入仓，运行产物不入仓）
frontend/test-results/
frontend/playwright-report/
frontend/playwright/.cache/


# ZCode agent skills (local tooling, not project code)
.agents/

# Python test/runtime cache
__pycache__/
*.py[cod]
