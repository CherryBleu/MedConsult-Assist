# MedConsult-Assist 基础设施环境变量（本地开发）
#
# 使用方法：
#   1. cp infra/.env.example infra/.env
#   2. 按需修改密码（生产环境必须改）
#   3. docker compose -f infra/docker-compose.yml up -d
#
# 红线 1：.env 文件不入仓（已在 .gitignore），生产环境用 KMS/Vault 注入。
#
# 注意：本文件既被 docker compose 读取（控制容器行为），
#       也作为 ai-service / 各业务服务运行时环境变量的集中参考。
#       启动 ai-service 前，把这些变量 export 到当前 shell 或写进 IDE 启动配置。

# === Nacos（Docker 内注册/配置中心）===
NACOS_ADDR=medconsult-nacos:8848
NACOS_NAMESPACE=public
NACOS_GROUP=DEFAULT_GROUP

# === MySQL ===
# 变量名与 ai-service / 各服务 application.yml 读取的 MYSQL_USER/MYSQL_PASSWORD 严格对齐。
MYSQL_ROOT_PASSWORD=root123456
MYSQL_USER=medconsult
MYSQL_PASSWORD=medconsult123
MYSQL_HOST=medconsult-mysql
MYSQL_PORT=3306

# === Qdrant（备用向量库，ai-service 当前走 Milvus，此项仅供预留）===
QDRANT_LOG_LEVEL=info

# === RabbitMQ ===
RABBITMQ_USER=medconsult
RABBITMQ_PASSWORD=medconsult123
RABBITMQ_HOST=medconsult-rabbitmq
RABBITMQ_PORT=5672

# === Redis ===
REDIS_HOST=medconsult-redis
REDIS_PORT=6379
REDIS_PASSWORD=

# === MongoDB（Docker 内疾病知识库）===
MONGODB_URI=mongodb://medconsult-mongodb:27017
MONGODB_HOST_PORT=27018
MONGODB_DATABASE=medconsult
MONGODB_COLLECTION=diseases

# === Milvus（向量检索；容器由 docker-compose 拉起）===
MILVUS_URI=http://medconsult-milvus:19530
MILVUS_TOKEN=root:Milvus
MILVUS_DATABASE=medical
MILVUS_COLLECTION=data
MILVUS_MIN_SCORE=0.60
MILVUS_METRIC_TYPE=COSINE
MILVUS_SEARCH_TIMEOUT_SECONDS=15

# === MinIO（影像文件存储；容器由 docker-compose 拉起）===
MINIO_ENDPOINT=http://medconsult-minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=medconsult

# === LLM（阿里云百炼，OpenAI 兼容；控制台 https://bailian.console.aliyun.com）===
ALIYUNBAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUNBAILIAN_APIKEY=sk-your-bailian-key-here
ALIYUNBAILIAN_MODEL=qwen3.7-plus
ALIYUNBAILIAN_TIMEOUT_SECONDS=60

# === Embedding（本地 Python 容器，bge-small-zh-v1.5，512 维）===
# 容器由 docker-compose 自动拉起（embedding 服务，端口 7997），随 compose up 启动。
# ai-service 的 EMBEDDING_BASE_URL 指向 Docker 内 embedding 服务；不需要 api-key。
EMBEDDING_BASE_URL=http://medconsult-embedding:7997/v1
EMBEDDING_API_KEY=not-needed
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIMENSION=512
# HuggingFace 模型下载镜像（国内加速，容器内已默认设置）
HF_ENDPOINT=https://hf-mirror.com

# === Frontend Nginx ===
GATEWAY_UPSTREAM=medconsult-gateway:8080

# === Docker 镜像仓库部署 ===
# 用 infra/docker-compose.registry.yml 从镜像仓库拉取部署时使用。
MEDCONSULT_IMAGE_REPOSITORY=cherrybleu/medconsult-assist
MEDCONSULT_IMAGE_TAG=latest

# === JWT ===
JWT_SECRET=dev-secret-0123456789abcdef0123456789abcdef-min32bytes
