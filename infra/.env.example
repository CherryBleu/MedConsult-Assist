# MedConsult-Assist 基础设施环境变量（本地开发）
#
# 使用方法：
#   1. cp infra/.env.example infra/.env
#   2. 按需修改密码（生产环境必须改）
#   3. docker compose -f infra/docker-compose.yml up -d
#
# 红线 1：.env 文件不入仓（已在 .gitignore），生产环境用 KMS/Vault 注入。
#
# 注意：本文件既被 docker compose 读取（控制容器行为），
#       也作为 ai-service / 各业务服务运行时环境变量的集中参考。
#       启动 ai-service 前，把这些变量 export 到当前 shell 或写进 IDE 启动配置。

# === MySQL ===
# 变量名与 ai-service / 各服务 application.yml 读取的 MYSQL_USER/MYSQL_PASSWORD 严格对齐。
MYSQL_ROOT_PASSWORD=root123456
MYSQL_USER=medconsult
MYSQL_PASSWORD=medconsult123

# === Qdrant（备用向量库，ai-service 当前走 Milvus，此项仅供预留）===
QDRANT_LOG_LEVEL=info

# === RabbitMQ ===
RABBITMQ_USER=medconsult
RABBITMQ_PASSWORD=medconsult123

# === MongoDB（本机安装，不走容器；ai-service 疾病知识库）===
# 连接串格式见 MongoDB 文档；默认本机无认证
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=medconsult
MONGODB_COLLECTION=diseases

# === Milvus（向量检索；容器由 docker-compose 拉起）===
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=root:Milvus
MILVUS_DATABASE=medical
MILVUS_COLLECTION=data
MILVUS_MIN_SCORE=0.60

# === MinIO（影像文件存储；容器由 docker-compose 拉起）===
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=medconsult

# === LLM（阿里云百炼，OpenAI 兼容；控制台 https://bailian.console.aliyun.com）===
ALIYUNBAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUNBAILIAN_APIKEY=sk-your-bailian-key-here
ALIYUNBAILIAN_MODEL=qwen-plus
ALIYUNBAILIAN_TIMEOUT_SECONDS=60

# === Embedding（本地 TEI 容器，bge-small-zh-v1.5，512 维）===
# 容器由 docker-compose 拉起，TEI 不需要 api-key（占位即可）
EMBEDDING_BASE_URL=http://localhost:7997/v1
EMBEDDING_API_KEY=not-needed
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIMENSION=512
