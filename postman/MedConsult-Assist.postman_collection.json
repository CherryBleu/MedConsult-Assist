                {"key": "receiverId", "value": "{{patientId}}", "description": "接收人编号（管理员可查任意人）"},
                {"key": "read", "value": "false", "description": "是否已读：true/false"},
                {"key": "page", "value": "1"},
                {"key": "pageSize", "value": "20"}
              ]
            },
            "description": "## 2.8.2 查询通知列表\n\n管理员可查任意人；普通用户当前阶段需管理员身份（JWT 无 userNo claim，RBAC 阶段精确化）。\n\n**需登录**。"
          }
        },
        {
          "name": "3. 标记已读",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}],
