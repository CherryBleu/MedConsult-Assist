              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "notifications", "{{notificationId}}", "read"]
            },
            "body": {"mode": "raw", "raw": "{}"},
            "description": "## 2.8.3 标记通知已读\n\n重复标记幂等（不报错）。\n\n**需登录**。"
          }
        }
      ]
    },
