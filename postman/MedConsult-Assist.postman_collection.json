              "raw": "{{baseUrl}}/api/v1/prescriptions",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "prescriptions"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"recordId\": \"{{recordId}}\",\n  \"patientId\": \"{{patientId}}\",\n  \"doctorId\": \"{{doctorId}}\",\n  \"source\": \"OUTPATIENT\",\n  \"items\": [\n    {\n      \"drugNo\": \"D10001\",\n      \"drugName\": \"硝苯地平控释片\",\n      \"specification\": \"30mg*7片\",\n      \"dosage\": \"30mg\",\n      \"frequency\": \"每日一次\",\n      \"route\": \"口服\",\n      \"days\": 7,\n      \"quantity\": 7,\n      \"unit\": \"片\",\n      \"unitPrice\": 3.50\n    }\n  ]\n}"
            },
            "description": "## 开方 POST /prescriptions\n\n初始 DRAFT，明细批量入库，累加 totalFee。\n\n**需登录（DOCTOR）**。"
          }
        },
        {
          "name": "2. 处方列表",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/prescriptions?status=DRAFT&page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "prescriptions"],
              "query": [
                {"key": "status", "value": "DRAFT", "description": "可空：DRAFT/PENDING_REVIEW/APPROVED/PAID/DISPENSED/COMPLETED/REJECTED/CANCELLED"},
                {"key": "page", "value": "1"},
                {"key": "pageSize", "value": "20"}
              ]
            },
            "description": "## 处方列表\n\n可按 status 过滤，分页。\n\n**需登录**。"
          }
        },
        {
          "name": "3. 处方详情",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/prescriptions/{{prescriptionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "prescriptions", "{{prescriptionId}}"]
            },
            "description": "## 处方详情\n\n主表 + 明细列表。\n\n**需登录**。"
          }
        },
        {
          "name": "4. 提交审方",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {
              "raw": "{{baseUrl}}/api/v1/prescriptions/{{prescriptionId}}/submit",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "prescriptions", "{{prescriptionId}}", "submit"]
            },
            "body": {"mode": "raw", "raw": "{}"},
            "description": "## 提交审方\n\nDRAFT → PENDING_REVIEW。\n\n**需登录（DOCTOR）**。"
          }
        },
        {
          "name": "5. 审方",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {
              "raw": "{{baseUrl}}/api/v1/prescriptions/{{prescriptionId}}/review",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "prescriptions", "{{prescriptionId}}", "review"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"APPROVE\",\n  \"pharmacistId\": \"PH2001\",\n  \"reviewComment\": \"用药合理\"\n}"
            },
            "description": "## 审方\n\nPENDING_REVIEW → APPROVED | REJECTED（Redis 锁防并发审方）。REJECT 需填 rejectReason。\n\n**需登录（PHARMACY_ADMIN）**。"
          }
        },
        {
          "name": "6. 缴费",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {
              "raw": "{{baseUrl}}/api/v1/prescriptions/{{prescriptionId}}/pay",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "prescriptions", "{{prescriptionId}}", "pay"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paidAmount\": 24.50,\n  \"paymentNo\": \"PAY20260710001\"\n}"
            },
            "description": "## 缴费\n\nAPPROVED → PAID。\n\n**需登录**。"
          }
        },
        {
          "name": "7. 调剂发药",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {
              "raw": "{{baseUrl}}/api/v1/prescriptions/{{prescriptionId}}/dispense",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "prescriptions", "{{prescriptionId}}", "dispense"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pharmacistId\": \"PH2001\"\n}"
            },
            "description": "## 调剂发药\n\nAPPROVED/PAID → DISPENSED。同步 Feign 逐条调 drug-service FEFO 出库，失败自动补偿回滚。\n\n**需登录（PHARMACY_ADMIN）**。"
          }
        },
        {
          "name": "8. 完成",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {
              "raw": "{{baseUrl}}/api/v1/prescriptions/{{prescriptionId}}/complete",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "prescriptions", "{{prescriptionId}}", "complete"]
            },
            "body": {"mode": "raw", "raw": "{}"},
            "description": "## 完成\n\nDISPENSED → COMPLETED。\n\n**需登录**。"
          }
        },
        {
          "name": "9. 退方",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {
              "raw": "{{baseUrl}}/api/v1/prescriptions/{{prescriptionId}}/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "prescriptions", "{{prescriptionId}}", "cancel"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cancelReason\": \"患者要求取消\",\n  \"operatorId\": \"PH2001\"\n}"
            },
            "description": "## 退方\n\nAPPROVED/PAID → CANCELLED（已调剂须走退药流程）。\n\n**需登录**。"
          }
        }
      ]
    },
    {
      "name": "Notification 通知",
      "description": "站内通知管理（接口文档 §2.8）",
      "item": [
        {
          "name": "1. 创建通知",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {
              "raw": "{{baseUrl}}/api/v1/notifications",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "notifications"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"receiverId\": \"{{patientId}}\",\n  \"receiverRole\": \"PATIENT\",\n  \"type\": \"APPOINTMENT\",\n  \"title\": \"预约成功\",\n  \"content\": \"你已成功预约门诊。\"\n}"
            },
            "description": "## 2.8.1 创建通知\n\n仅管理员可调（业务通知走 MQ 或 /internal/notifications）。\n\n**需登录（HOSPITAL_ADMIN / PHARMACY_ADMIN）**。"
          }
