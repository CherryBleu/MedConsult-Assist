  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('HTTP 2xx', function () { pm.expect(pm.response.code).to.be.within(200, 299); });",
          "const contentType = pm.response.headers.get('Content-Type') || '';",
          "if (contentType.includes('application/json')) {",
          "  const json = pm.response.json();",
          "  pm.test('Unified response', function () {",
          "    pm.expect(json).to.have.property('code');",
          "    pm.expect(json).to.have.property('message');",
          "    pm.expect(json).to.have.property('traceId');",
          "    pm.expect(json).to.have.property('timestamp');",
          "  });",
          "}"
        ]
      }
    }
  ],
  "item": [
