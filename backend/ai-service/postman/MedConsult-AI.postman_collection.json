              "raw": "{\n  \"sessionId\": \"{{sessionId}}\",\n  \"patientId\": \"{{patientId}}\",\n  \"message\": \"我最近三天胸闷、心悸，活动后明显，应该挂什么科？如果出现胸痛和呼吸困难怎么办？\",\n  \"patientContext\": {\n    \"age\": 38,\n    \"gender\": \"MALE\",\n    \"allergies\": [\"青霉素\"],\n    \"pastMedicalHistory\": [\"高血压\"]\n  },\n  \"ragOptions\": {\n    \"knowledgeSource\": \"DISEASE_JSON\",\n    \"topK\": 5,\n    \"returnCitations\": true\n  }\n}"
